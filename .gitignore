# ================================
# JAMAN — Next.js .gitignore
# ================================

# ── Dependencies ──
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Next.js Build Output ──
.next/
out/
build/
dist/

# ── Production ──
*.tsbuildinfo
next-env.d.ts

# ── Environment Variables ──
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ── Debug & Logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
logs/

# ── OS Files ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor & IDE ──
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.history/

# ── TypeScript ──
*.js.map
*.d.ts.map

# ── Testing ──
coverage/
.nyc_output/
cypress/videos/
cypress/screenshots/

# ── Misc ──
*.zip
*.tar.gz
.cache/
.parcel-cache/
.turbo/
.vercel/
.netlify/
